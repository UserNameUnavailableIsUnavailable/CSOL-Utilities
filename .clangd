# Global library paths and macros
CompileFlags:
  Add:
    - -Ibuild/vcpkg_installed/x64-windows/include
    - -Ibuild/vcpkg_installed/x64-windows/include/opencv4
    - -Ibuild/gen
    - -D_DEBUG
    - -DVERSION
Completion:
  HeaderInsertion: Never
---
# C++
If:
  PathMatch: .*\.(hpp|hxx|hh|h|cpp|cxx|cc)$
CompileFlags:
  Add: ["-x", "c++", "-std=c++20"]
---
# C
If:
  PathMatch: .*\.(c)$
CompileFlags:
  Add: ["-std=c17"]
---
# Controller
If:
  PathMatch: Controller/.*
CompileFlags:
  Add: [
    "-Ibuild/dependencies/include",
    "-IController/include",
    "-include pch.hpp"
  ]
---
# Tool
If:
  PathMatch: Tool/.*
CompileFlags:
  Add: ["-ITool/include"]